    {
      "numero": 7,
      "texto": "A norma do §3º do artigo 192 da Constituição, revogada pela Emenda Constitucional nº 40/2003, que limitava a taxa de juros reais a 12% ao ano, tinha sua aplicação condicionada à edição de lei complementar.",
      "data_aprovacao": "2008-06-12",
      "revogada": false,
      "fonte_url": "https://portal.stf.jus.br/jurisprudencia/sumariosumulas.asp?base=26&sumula=1217",
      "fetched_at": "2026-05-05T22:00:00Z",
      "hash_sha256": "bc640fd5ee67d81acde8d32cd09bafb4b94c3b641aaea8111cd326f84a2c90b3"
    },
    {
      "numero": 25,
      "texto": "É ilícita a prisão civil de depositário infiel, qualquer que seja a modalidade do depósito.",
      "data_aprovacao": "2009-12-16",
      "revogada": false,
      "fonte_url": "https://portal.stf.jus.br/jurisprudencia/sumariosumulas.asp?base=26&sumula=1264",
