      "hash_sha256": "3eafa3bb145190074e2260400c83c4359f80d00893c2cab2d47345200751247c"
    },
    {
      "numero": 28,
      "texto": "É inconstitucional a exigência de depósito prévio como requisito de admissibilidade de ação judicial na qual se pretenda discutir a exigibilidade de crédito tributário.",
      "data_aprovacao": "2010-02-17",
      "revogada": false,
      "fonte_url": "https://portal.stf.jus.br/jurisprudencia/sumariosumulas.asp?base=26&sumula=1267",
      "fetched_at": "2026-05-05T22:00:00Z",
