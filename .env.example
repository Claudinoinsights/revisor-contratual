# ═══════════════════════════════════════════════════════════════════════════
# Revisor Contratual — .env.example (template público)
#
# ⚠️  CRITICAL (CC.40 fix F-16): NUNCA use os placeholders abaixo como valores
# reais. Cada var crítica tem comando shell para gerar valor seguro.
# `cp .env.example .env` SEM editar resulta em app que não roda (auth falha)
# OU roda inseguro (chaves placeholder). EDITE SEMPRE antes de usar.
#
# Como usar (passo-a-passo):
#   1. cp .env.example .env
#   2. Para cada var crítica abaixo: rode o comando indicado e cole o output
#   3. chmod 600 .env (Linux/Mac) — Windows usa ACL do diretório
#   4. python -m bloco_interface.web.app  (verifica que sobe sem warning)
#
# IMPORTANTE: este arquivo é commitado (sem segredos reais — só placeholders).
# O .env real é gitignored — NUNCA commite.
# ═══════════════════════════════════════════════════════════════════════════

# ─── CRÍTICOS (sem eles app não funciona corretamente) ──────────────────────

# 1. AUTH_COOKIE_KEY — HMAC do GENESIS audit chain (ADR-005)
#    Gerar UMA VEZ via:  python -c "import secrets; print(secrets.token_hex(32))"
#    APÓS gerar, rodar: revisor init-audit (cria GENESIS lock assinado por esta chave)
#    NUNCA alterar depois — invalida audit log existente
#    Rotação segura: ver docs/sop-rotacao-auth-cookie-key.md
AUTH_COOKIE_KEY=<32-bytes-hex-gerados-por-secrets.token_hex(32)>

# 2. ADMIN_USERNAME — login user single-user solo (ADR-013 §2.2)
ADMIN_USERNAME=admin

# 3. ADMIN_PASSWORD_HASH — bcrypt rounds=12 hash da senha admin
#    Gerar via: python -c "import bcrypt; print(bcrypt.hashpw(b'SUA_SENHA', bcrypt.gensalt(rounds=12)).decode())"
#    NOTA: DEFAULT_PASSWORD_HASH em auth.py:27 é INVÁLIDO (TD-AUTH-DEFAULT-HASH-INVALID HIGH)
#    Sem este env, app é 100% inacessível mesmo em dev
ADMIN_PASSWORD_HASH=<bcrypt-hash-gerado-via-bcrypt.hashpw>

# 4. REVISOR_SECRET_KEY — Starlette SessionMiddleware secret
#    Gerar via: python -c "import secrets; print(secrets.token_hex(32))"
#    Sem isto, sessions expiram a cada restart do app (warning na startup)
REVISOR_SECRET_KEY=<32-bytes-hex-gerados-por-secrets.token_hex(32)>

# 5. FERNET_KEY — LGPD camada 4 cifragem PDFs uploads (FR-LGPD-MVP-01d)
#    Gerar via: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#    Formato: 44 chars base64-urlsafe terminando em '='
#    Sem isto, PDFs cifrados não persistem após restart (key efêmera in-memory)
FERNET_KEY=<chave-Fernet-gerada-via-Fernet.generate_key()>

# ─── OPCIONAIS (têm defaults razoáveis) ──────────────────────────────────────

# 6. REVISOR_DATA_DIR — override pasta de dados
#    Default: ~/.local/share/revisor-contratual/
#    Contém: vault.db, audit.jsonl, .audit-genesis.lock, bacen-cache/
# REVISOR_DATA_DIR=/caminho/customizado

# 7. REVISOR_HTTPS_ONLY — flag Secure no session cookie
#    0 = dev (HTTP localhost OK)
#    1 = produção (exige HTTPS no proxy/LB ou cookie é descartado)
REVISOR_HTTPS_ONLY=0

# 8. OLLAMA_BINARY_PATH — override auto-detect Ollama
#    Default: auto-detecta via PATH ou paths conhecidos por SO
#    Windows: %LOCALAPPDATA%\Programs\Ollama\ollama.exe
#    Linux:   /usr/local/bin/ollama
#    macOS:   /opt/homebrew/bin/ollama
# OLLAMA_BINARY_PATH=/caminho/customizado/ollama

# 9. ENABLE_TEMA_1378_AUTO_CHECK — feature flag CC.25 monitor STJ Tema 1378
#    false = scheduler NÃO registra job 3 (default seguro)
#    true  = scheduler registra job 3 com pull periódico STJ Tema 1378
ENABLE_TEMA_1378_AUTO_CHECK=false

# 10. HF_TOKEN — Hugging Face Hub token (rate limits maiores)
#     Opcional — BERTimbau embeddings (vault busca semântica) funciona sem,
#     com warning de rate limit no startup
#     Obter em: https://huggingface.co/settings/tokens
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── API KEYS EXTERNAS ───────────────────────────────────────────────────────
# NENHUMA NECESSÁRIA. Sistema 100% local:
#   - LLMs: Ollama local (Sabia 7B + Qwen 7B/3B)
#   - Jurisprudência STJ + STF: scrapers HTML público sem auth
#   - BACEN SGS: API pública (https://api.bcb.gov.br/dados/serie/) sem auth

# ═══════════════════════════════════════════════════════════════════════════
# Sprint 04 — Cloud SaaS BYOK Multi-tenant (SP04-AUTH-01)
#
# Sprint 04 introduz PostgreSQL multi-tenant Pool+RLS (ADR-017 BACKBONE) ao
# lado da arquitetura SQLite Sprint 03. As variáveis abaixo são CRÍTICAS para
# auth/onboarding/DPA flow funcionarem (SP04-AUTH-01).
#
# Sprint 03 vars acima permanecem válidas para vault/audit-chain SQLite —
# ainda não migrados (ADR-007 superseded por ADR-017, código pendente Sprint
# 05+ refactor).
# ═══════════════════════════════════════════════════════════════════════════

# 11. DATABASE_URL — PostgreSQL 16 connection (SP04-AUTH-01 / ADR-017)
#     Formato async asyncpg: postgresql+asyncpg://user:pass@host:port/dbname
#     Local dev: postgresql+asyncpg://revisor:revisor@localhost:5432/revisor_sp04
#     Container: postgresql+asyncpg://revisor:revisor@postgres:5432/revisor_sp04
#     Extensions necessárias: pgcrypto (gen_random_uuid + hashing) — auto-criadas
#     pela migration sp04_001_auth_multitenant.sql
DATABASE_URL=postgresql+asyncpg://revisor:revisor@localhost:5432/revisor_sp04

# 12. JWT_SECRET_KEY — HS256 secret para login JWT (SP04-AUTH-01 AC-05 / FR-AUTH-03)
#     Gerar UMA VEZ via: python -c "import secrets; print(secrets.token_hex(32))"
#     Distinto de REVISOR_SECRET_KEY (que é Starlette session middleware Sprint 03)
#     Rotação invalida TODOS JWTs ativos — força re-login. Documentar SOP.
JWT_SECRET_KEY=<32-bytes-hex-gerados-por-secrets.token_hex(32)>

# 13. JWT_EXPIRY_HOURS — duração do JWT em horas (Smith F-008 — explicit)
#     Default story SP04-AUTH-01 AC-05: 24h
#     Aumentar invalida promessa segurança; diminuir aumenta UX friction
JWT_EXPIRY_HOURS=24

# 14. JWT_ALGORITHM — algoritmo de assinatura JWT
#     Default: HS256 (story spec). Sprint 05+ pode promover para RS256 (asym)
JWT_ALGORITHM=HS256

# 15. DPA_TEMPLATES_DIR — diretório dos textos canônicos DPA (ADR-019)
#     Default: governance/legal/dpa-templates/
#     Texto v1.0.0 substantivo redigido por Eric (advogado responsável LGPD)
#     Implementação SP04-AUTH-01 lê filesystem + computa SHA-256 hash on-demand
DPA_TEMPLATES_DIR=governance/legal/dpa-templates
